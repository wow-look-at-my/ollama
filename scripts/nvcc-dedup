#!/bin/bash
#
# nvcc compilation cache that deduplicates identical virtual architectures.
#
# For each nvcc invocation with multiple -gencode flags, this wrapper:
# 1. Preprocesses the source for each virtual arch and hashes the output
# 2. Builds a cache key from the unique set of preprocessed hashes
# 3. On cache hit: copies the cached object file directly (skips nvcc)
# 4. On cache miss: compiles with only the unique arches, caches the result
#
# SASS arches (code=sm_*) are never deduplicated — they produce
# architecture-specific machine code even from identical source.
#
# Set CMAKE_CUDA_COMPILER_LAUNCHER to this script.

set -euo pipefail

NVCC="$1"
shift

CACHE_DIR="${NVCC_DEDUP_CACHE_DIR:-/tmp/nvcc-dedup-cache}"
mkdir -p "$CACHE_DIR"

# Find the output file (-o flag) and source file (.cu).
output_file=""
src_file=""
prev=""
include_flags=()
for arg in "$@"; do
    if [ "$prev" = "-o" ]; then
        output_file="$arg"
    fi
    case "$arg" in
        *.cu) src_file="$arg" ;;
        -I*|-isystem*|--include-path*) include_flags+=("$arg") ;;
    esac
    prev="$arg"
done

# If no output or source, or <= 1 gencode, just pass through.
gencode_count=0
for arg in "$@"; do
    case "$arg" in -gencode*|--generate-code*) gencode_count=$((gencode_count + 1));; esac
done
if [ -z "$output_file" ] || [ -z "$src_file" ] || [ ! -f "$src_file" ] || [ "$gencode_count" -le 1 ]; then
    exec "$NVCC" "$@"
fi

# Preprocess each virtual arch, hash the output, group by hash.
declare -A hash_to_first_arch  # hash -> first -gencode flag with this hash
declare -A arch_hashes         # -gencode flag -> hash
sass_gencodes=()
virtual_gencodes=()

for arg in "$@"; do
    case "$arg" in
        -gencode=*|--generate-code=*)
            gencode="${arg#*=}"
            code_val=""
            [[ "$gencode" =~ code=([a-z_0-9]+) ]] && code_val="${BASH_REMATCH[1]}"

            if [[ "$code_val" != compute_* ]]; then
                sass_gencodes+=("$arg")
                continue
            fi

            virtual_gencodes+=("$arg")
            arch_val=""
            [[ "$gencode" =~ arch=([a-z_0-9]+) ]] && arch_val="${BASH_REMATCH[1]}"

            if [ -n "$arch_val" ]; then
                # Normalize out __CUDA_ARCH__-derived values so arches with
                # identical code paths hash the same. The only non-guard use
                # of __CUDA_ARCH__ is in no_device_code() calls.
                pp_hash=$("$NVCC" -E -arch="$arch_val" "${include_flags[@]}" "$src_file" 2>/dev/null \
                    | grep -v '^#' \
                    | sed 's/no_device_code([^)]*)/no_device_code()/g' \
                    | md5sum | cut -d' ' -f1) || pp_hash="$arg"
                arch_hashes["$arg"]="$pp_hash"
                if [ -z "${hash_to_first_arch[$pp_hash]+x}" ]; then
                    hash_to_first_arch["$pp_hash"]="$arg"
                fi
            fi
            ;;
    esac
done

# Build the set of unique virtual gencodes.
unique_gencodes=()
for arg in "${virtual_gencodes[@]}"; do
    h="${arch_hashes[$arg]}"
    if [ "${hash_to_first_arch[$h]}" = "$arg" ]; then
        unique_gencodes+=("$arg")
    fi
done

# Cache key: hash of (all non-gencode flags + unique gencode set + source hash).
src_hash=$(md5sum "$src_file" | cut -d' ' -f1)
flags_for_key=""
for arg in "$@"; do
    case "$arg" in -gencode*|--generate-code*) ;; *) flags_for_key+="$arg ";; esac
done
for g in "${unique_gencodes[@]}" "${sass_gencodes[@]}"; do
    flags_for_key+="$g "
done
cache_key=$(printf '%s\n%s' "$flags_for_key" "$src_hash" | md5sum | cut -d' ' -f1)
cached="$CACHE_DIR/$cache_key.o"

# Cache hit: copy cached object file.
if [ -f "$cached" ]; then
    cp "$cached" "$output_file"
    exit 0
fi

# Cache miss: compile with only unique arches + all SASS arches.
new_args=()
for arg in "$@"; do
    case "$arg" in
        -gencode=*|--generate-code=*)
            # Skip — we'll add the kept ones at the end.
            ;;
        *)
            new_args+=("$arg")
            ;;
    esac
done
new_args+=("${unique_gencodes[@]}" "${sass_gencodes[@]}")

"$NVCC" "${new_args[@]}"

# Cache the result.
if [ -f "$output_file" ]; then
    cp "$output_file" "$cached"
fi
